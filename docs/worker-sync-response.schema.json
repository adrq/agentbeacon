{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.agentmaestro.dev/worker-sync-response.schema.json",
  "title": "Worker Sync Response",
  "description": "Response sent by scheduler to worker during sync cycle. Session-based protocol.",
  "oneOf": [
    { "$ref": "#/definitions/NoActionResponse" },
    { "$ref": "#/definitions/SessionAssignedResponse" },
    { "$ref": "#/definitions/PromptDeliveryResponse" },
    { "$ref": "#/definitions/SessionCompleteResponse" },
    { "$ref": "#/definitions/CommandResponse" }
  ],
  "definitions": {
    "NoActionResponse": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "no_action",
          "description": "No work available or heartbeat ack. Worker should continue polling."
        }
      }
    },
    "SessionAssignedResponse": {
      "type": "object",
      "required": ["type", "sessionId", "task"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "session_assigned",
          "description": "New session assignment for worker to execute."
        },
        "sessionId": {
          "type": "string",
          "minLength": 1,
          "description": "Scheduler session ID assigned to this worker."
        },
        "task": {
          "$ref": "#/definitions/TaskAssignment"
        }
      }
    },
    "PromptDeliveryResponse": {
      "type": "object",
      "required": ["type", "sessionId", "task"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "prompt_delivery",
          "description": "New prompt/task for an existing session."
        },
        "sessionId": {
          "type": "string",
          "minLength": 1,
          "description": "Scheduler session ID this prompt belongs to."
        },
        "task": {
          "$ref": "#/definitions/TaskAssignment"
        }
      }
    },
    "SessionCompleteResponse": {
      "type": "object",
      "required": ["type", "sessionId"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "session_complete",
          "description": "Session reached terminal state. Worker should release it."
        },
        "sessionId": {
          "type": "string",
          "minLength": 1,
          "description": "Scheduler session ID that completed."
        }
      }
    },
    "CommandResponse": {
      "type": "object",
      "required": ["type", "command"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "command",
          "description": "Control command from scheduler to worker."
        },
        "command": {
          "$ref": "#/definitions/WorkerCommand"
        }
      }
    },
    "TaskAssignment": {
      "type": "object",
      "required": ["executionId", "sessionId", "taskPayload"],
      "additionalProperties": false,
      "properties": {
        "executionId": {
          "type": "string",
          "minLength": 1,
          "description": "Execution identifier for task correlation."
        },
        "sessionId": {
          "type": "string",
          "minLength": 1,
          "description": "Session identifier this task belongs to."
        },
        "taskPayload": {
          "type": "object",
          "description": "Task payload containing agent_id, agent_type, agent_config, sandbox_config, and message."
        }
      }
    },
    "WorkerCommand": {
      "type": "string",
      "enum": ["cancel", "shutdown"],
      "description": "Control commands: 'cancel' = abort current task, 'shutdown' = graceful worker termination."
    }
  },
  "examples": [
    {
      "description": "No tasks available",
      "data": { "type": "no_action" }
    },
    {
      "description": "Session assignment with initial task",
      "data": {
        "type": "session_assigned",
        "sessionId": "sess-123",
        "task": {
          "executionId": "exec-456",
          "sessionId": "sess-123",
          "taskPayload": {
            "agent_id": "agent-1",
            "agent_type": "claude_sdk",
            "agent_config": {},
            "sandbox_config": null,
            "message": {
              "role": "user",
              "parts": [{ "kind": "text", "text": "Implement auth" }]
            }
          }
        }
      }
    },
    {
      "description": "Prompt delivery for existing session",
      "data": {
        "type": "prompt_delivery",
        "sessionId": "sess-123",
        "task": {
          "executionId": "exec-456",
          "sessionId": "sess-123",
          "taskPayload": {
            "kind": "handoff_result",
            "child_session_id": "sess-789",
            "message": "Task completed successfully"
          }
        }
      }
    },
    {
      "description": "Session complete",
      "data": {
        "type": "session_complete",
        "sessionId": "sess-123"
      }
    },
    {
      "description": "Cancel command",
      "data": { "type": "command", "command": "cancel" }
    }
  ]
}
